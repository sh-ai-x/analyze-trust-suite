# Local API keys — copy to .env and fill in. .env is gitignored.

# Default provider for /review-code (pre-commit + GitHub Action).
MINMAX_API_KEY=

# Opt-in: real Claude Code (Anthropic API).
#   Pre-commit: REVIEW_PROVIDER=anthropic git commit ...
#   GitHub Action: Actions → PR Review (MiniMax) → review_provider: anthropic
ANTHROPIC_API_KEY=